{
  "validation_config": {
    "name": "Frame Source Map Validation",
    "version": "1.0.0",
    "description": "Source of truth validation for Frame transpiler source maps",
    "author": "Frame Development Team"
  },
  
  "quality_standards": {
    "minimum_executable_coverage": 95,
    "maximum_acceptable_duplicates": 5,
    "critical_duplicate_threshold": 10,
    "required_constructs": [
      "main_function",
      "interface_methods", 
      "system_constructors"
    ]
  },
  
  "bug_detection_patterns": {
    "bug_27_event_handlers": {
      "pattern": "() {",
      "description": "Event handler declarations with duplicate mappings",
      "severity": "minor"
    },
    "bug_27_transitions": {
      "pattern": "-> $",
      "description": "State transitions with duplicate mappings", 
      "severity": "minor"
    }
  },
  
  "test_integration": {
    "enabled_by_default": false,
    "run_on_ci": true,
    "fail_on_quality_issues": false,
    "generate_reports_for_vscode": true,
    "report_output_path": "/tmp/frame_source_map_quality.json"
  },
  
  "vscode_extension_interface": {
    "validation_command": "python3 /Users/marktruluck/projects/frame_transpiler/tools/source_map_test_integration.py",
    "single_file_validation": "--file",
    "quality_report_flag": "--report",
    "expected_report_format": "json",
    "quality_thresholds": {
      "excellent": 95,
      "good": 90,
      "fair": 80,
      "poor": 50
    }
  },
  
  "output_formats": {
    "console": {
      "enabled": true,
      "verbose_mode": false,
      "show_bug_patterns": true
    },
    "json_report": {
      "enabled": true,
      "include_file_details": true,
      "include_recommendations": true,
      "include_bug_analysis": true
    },
    "ci_summary": {
      "enabled": true,
      "format": "github_actions"
    }
  }
}