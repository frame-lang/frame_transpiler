{
    "name": "Multi-File Module System Tests",
    "description": "Tests for Frame v0.57 multi-file module system",
    "tests": [
        {
            "name": "Basic multi-file compilation",
            "files": ["test_multifile_main.frm"],
            "multifile": true,
            "expected_output": ["5 + 3 = 8", "4 * 7 = 28", "Area of circle", "10 is even", "7 is odd", "Direct calculation: 300", "PI value: 3.14159"]
        },
        {
            "name": "Complex multi-file with multiple dependencies",
            "files": ["test_multifile_complex.frm"],
            "multifile": true,
            "expected_output": ["10 + 5 = 15", "7 * 8 = 56", "2 ^ 8 = 256", "Hello, Frame!", "Reversed: olleH", "Formatted PI: 3.14", "Parsed: 42.5"]
        },
        {
            "name": "Circular dependency detection",
            "files": ["test_circular_main.frm"],
            "multifile": true,
            "should_fail": true,
            "expected_error": "Circular dependency detected"
        }
    ],
    "settings": {
        "timeout": 10,
        "python_version": "python3",
        "framec_flags": ["-m", "-l", "python_3"]
    }
}