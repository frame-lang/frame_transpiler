// Re-export the main compile function
pub use self::compile_module_v4 as compile_module;

// V4 Compiler interface for CLI compatibility
pub struct FrameV4Compiler {
    target: TargetLanguage,
}

impl FrameV4Compiler {
    pub fn new(target: TargetLanguage) -> Self {
        Self { target }
    }
    
    pub fn compile(&self, source: &str, _file_path: &str) -> FrameV4Result {
        match compile_module_v4(source, self.target) {
            Ok(code) => FrameV4Result::Ok(FrameV4Output {
                code,
                warnings: Vec::new(),
                source_map: None,
            }),
            Err(e) => FrameV4Result::Err(ErrorsAcc {
                errors: vec![e.error],
            }),
        }
    }
}

// V4 Result types for CLI compatibility
pub enum FrameV4Result {
    Ok(FrameV4Output),
    Err(ErrorsAcc),
}

pub struct FrameV4Output {
    pub code: String,
    pub warnings: Vec<String>,
    pub source_map: Option<String>,
}

pub struct ErrorsAcc {
    pub errors: Vec<String>,
}

impl ErrorsAcc {
    pub fn new() -> Self {
        Self { errors: Vec::new() }
    }
    
    pub fn push_error(&mut self, error: String) {
        self.errors.push(error);
    }
    
    pub fn errors(&self) -> &[String] {
        &self.errors
    }
}

// Main v4 compilation function - evolved from v3's compile_module
pub fn compile_module_v4(content_str: &str, lang: TargetLanguage) -> Result<String, RunError> {
    // V4 changes: Handle @@target, @@system, @@persist
    // For now, this is identical to v3's logic, we'll modify incrementally
    
    // Partition file into bodies and rewrite each body via the V4 pipeline.
    let bytes = content_str.as_bytes();
    let parts = match module_partitioner::ModulePartitionerV3::partition(bytes, lang) {
        Ok(p) => p,
        Err(e) => return Err(RunError::new(frame_exitcode::PARSE_ERR, &e.0)),
    };
    
    // Stage 10: Prefer Arcanum-derived system name for expansion context
    let arc_for_ctx = crate::frame_c::v4::arcanum::build_arcanum_from_outline_bytes(bytes, 0);
    
    // Check if this is a module (not a system)
    let module_name = find_module_name(bytes, 0);
    let is_module = module_name.is_some();
    
    if std::env::var("FRAME_TRANSPILER_DEBUG").is_ok() {
        eprintln!("[v4::compile_module] module_name = {:?}, is_module = {}", module_name, is_module);
    }
    
    let system_name = {
        // pick the first declared system if present; otherwise fallback to textual scan
        if let Some((name, _)) = arc_for_ctx.systems.iter().next() { 
            Some(name.clone()) 
        } else { 
            find_system_name(bytes, 0) 
        }
    };
    
    // Continue with v3 logic for now - we'll modify this incrementally
    compile_v3_logic(content_str, lang, parts, arc_for_ctx, module_name, system_name)
}

// Helper functions from v3 (we'll modify these for v4 as needed)
fn find_module_name(bytes: &[u8], start: usize) -> Option<String> {
    // TODO: Update to handle v4 syntax
    crate::frame_c::v3::find_module_name(bytes, start)
}

fn find_system_name(bytes: &[u8], start: usize) -> Option<String> {
    // TODO: Update to handle @@system syntax
    crate::frame_c::v3::find_system_name(bytes, start)
}

// Temporarily use v3 logic while transitioning
fn compile_v3_logic(
    content_str: &str,
    lang: TargetLanguage,
    _parts: module_partitioner::ModulePartitionsV3,
    _arc_for_ctx: arcanum::Arcanum,
    _module_name: Option<String>,
    _system_name: Option<String>,
) -> Result<String, RunError> {
    // This is v3's compile logic - we'll gradually make it v4-native
    // For now, just call the v3 version to avoid infinite loop
    crate::frame_c::v3::compile_module(content_str, lang)
}